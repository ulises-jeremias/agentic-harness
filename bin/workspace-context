#!/usr/bin/env bash
# workspace-context — session state snapshot for AI Workspace
# Outputs a summary of current workspace state to inject at session start.
# Usage:
#   ./bin/workspace-context           # Print snapshot to stdout
#   ./bin/workspace-context load packs/<pack>.yaml   # Load a context pack

set -euo pipefail

WORKSPACE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
KNOWLEDGE="${WORKSPACE_ROOT}/knowledge"
PROJECTS_DIR="${WORKSPACE_ROOT}/projects"
PERSONAS_DIR="${WORKSPACE_ROOT}/personas"
PACKS_DIR="${WORKSPACE_ROOT}/packs"

# ── colors ────────────────────────────────────────────────────────────────────
_use_color() { [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; }
blue()   { _use_color && printf '\033[1;34m%s\033[0m\n' "$*" || echo "$*"; }
green()  { _use_color && printf '\033[1;32m%s\033[0m\n' "$*" || echo "$*"; }
yellow() { _use_color && printf '\033[1;33m%s\033[0m\n' "$*" || echo "$*"; }
dim()    { _use_color && printf '\033[0;37m%s\033[0m\n' "$*" || echo "$*"; }

# ── snapshot ──────────────────────────────────────────────────────────────────

cmd_snapshot() {
  echo ""
  blue "=== AI Workspace — Session Context ==="
  echo ""

  # Date
  echo "Date       : $(date '+%Y-%m-%d %H:%M %Z')"
  echo "Workspace  : ${WORKSPACE_ROOT}"
  echo ""

  # Git branch
  if git -C "${WORKSPACE_ROOT}" rev-parse --git-dir > /dev/null 2>&1; then
    branch=$(git -C "${WORKSPACE_ROOT}" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
    echo "Branch     : ${branch}"
  fi
  echo ""

  # Indexed projects
  blue "── Projects ──────────────────────────────────────────────"
  if [[ -d "${PROJECTS_DIR}" ]]; then
    count=0
    while IFS= read -r -d '' link; do
      name=$(basename "$link")
      target=$(readlink -f "$link" 2>/dev/null || echo "(broken)")
      printf "  %-30s → %s\n" "${name}" "${target}"
      (( count+=1 ))
    done < <(find "${PROJECTS_DIR}" -maxdepth 1 -type l -print0 2>/dev/null | sort -z)
    if [[ $count -eq 0 ]]; then
      dim "  (no projects indexed — run: bin/project-indexer clone owner/repo)"
    fi
  else
    dim "  (projects/ directory not found)"
  fi
  echo ""

  # Pending todos
  blue "── Pending Todos ──────────────────────────────────────────"
  todos_file="${KNOWLEDGE}/todos/pending.md"
  if [[ -f "${todos_file}" ]]; then
    # Show unchecked items only
    unchecked=$(grep -E '^\- \[ \]' "${todos_file}" 2>/dev/null || true)
    if [[ -n "${unchecked}" ]]; then
      echo "${unchecked}" | head -10
    else
      dim "  (no pending todos)"
    fi
  else
    dim "  (no todos file)"
  fi
  echo ""

  # Recent learnings (last 3)
  blue "── Recent Learnings ───────────────────────────────────────"
  learnings_file="${KNOWLEDGE}/learnings/general.md"
  if [[ -f "${learnings_file}" ]]; then
    # Extract last few table rows from the history section
    recent=$(grep -E '^\| [0-9]{4}' "${learnings_file}" 2>/dev/null | tail -3 || true)
    if [[ -n "${recent}" ]]; then
      echo "${recent}"
    else
      dim "  (no learnings recorded yet)"
    fi
  fi
  echo ""

  # Active persona (if any) — emit constraints block for AI tool enforcement
  if [[ -d "${PERSONAS_DIR}" ]]; then
    active_persona="${WORKSPACE_ROOT}/.active-persona"
    if [[ -f "${active_persona}" ]]; then
      persona=$(cat "${active_persona}")
      persona_file="${PERSONAS_DIR}/${persona}.md"
      blue "── Active Persona ─────────────────────────────────────────"
      echo "  Persona: ${persona}"
      echo ""
      if [[ -f "${persona_file}" ]]; then
        python3 - "${persona_file}" "${persona}" <<'PYEOF'
import json, pathlib, sys, re
from typing import Any

file_path, persona_name = pathlib.Path(sys.argv[1]), sys.argv[2]
content = file_path.read_text(encoding="utf-8")

# Extract YAML frontmatter
lines = content.splitlines()
if lines and lines[0].strip() == "---":
    end = next((i for i, l in enumerate(lines[1:], 1) if l.strip() == "---"), None)
    if end:
        fm = "\n".join(lines[1:end])
        import yaml
        try:
            meta: dict[str, Any] = yaml.safe_load(fm) or {}
        except Exception:
            meta = {}
    else:
        meta = {}
else:
    meta = {}

allow = meta.get("allow", [])
deny = meta.get("deny", [])
handoffs = meta.get("handoffs", [])
output_fmt = meta.get("output_format", "")

print("  <persona-constraints>")
print(f"    persona: {persona_name}")
if allow:
    print(f"    allow: [{', '.join(allow)}]")
if deny:
    print(f"    deny: [{', '.join(deny)}]")
if output_fmt:
    print(f"    output_format: {output_fmt}")
if handoffs:
    print("    handoffs:")
    for h in handoffs:
        when = h.get("when", "")
        to = h.get("to", "")
        print(f'      - when: "{when}"')
        print(f"        to: {to}")
print("  </persona-constraints>")
PYEOF
      fi
      echo ""
    fi
  fi

  # Active pack (if any)
  active_pack="${WORKSPACE_ROOT}/.active-pack"
  if [[ -f "${active_pack}" ]]; then
    pack=$(cat "${active_pack}")
    blue "── Active Pack ────────────────────────────────────────────"
    echo "  ${pack}"
    echo ""
  fi

  # Loop spend summary (7d) — shown when loops/ directory exists
  loops_dir="${WORKSPACE_ROOT}/loops"
  if [[ -d "${loops_dir}" ]]; then
    blue "── Loop Spend (7d) ────────────────────────────────────────"
    python3 - "${loops_dir}" <<'PYEOF'
import json, pathlib, sys
from datetime import datetime, timezone, timedelta

loops_dir = pathlib.Path(sys.argv[1])
cutoff = datetime.now(timezone.utc) - timedelta(days=7)

total_tokens = 0
total_runs = 0
failed_runs = 0

for trace in sorted(loops_dir.rglob("trace.jsonl")):
    for line in trace.read_text(encoding="utf-8").splitlines():
        try:
            ev = json.loads(line)
            ts_str = ev.get("ts", "")
            try:
                ts = datetime.fromisoformat(ts_str.replace("Z", "+00:00"))
            except (ValueError, AttributeError):
                continue
            if ts < cutoff:
                continue
            if ev.get("kind") == "run_start":
                total_runs += 1
            elif ev.get("kind") == "run_end" and ev.get("status") != "completed":
                failed_runs += 1
            total_tokens += ev.get("prompt_tokens", 0) + ev.get("completion_tokens", 0)
        except (json.JSONDecodeError, TypeError):
            pass

if total_runs == 0:
    print("  (no loop runs in the last 7 days)")
else:
    success = total_runs - failed_runs
    print(f"  Runs: {total_runs}  Success: {success}  Failed: {failed_runs}")
    print(f"  Tokens (approx): {total_tokens:,}")
PYEOF
    echo ""
  fi

  # AGENTS.md spec hash (for reproducibility)
  agents_md="${WORKSPACE_ROOT}/AGENTS.md"
  if [[ -f "${agents_md}" ]]; then
    spec_hash=$(python3 -c "import hashlib, pathlib; h=hashlib.sha256(pathlib.Path('${agents_md}').read_bytes()).hexdigest()[:12]; print(h)" 2>/dev/null || echo "?")
    echo "Spec       : AGENTS.md@${spec_hash}"
    echo ""
  fi

  blue "──────────────────────────────────────────────────────────"
  echo ""
}

# ── load pack ─────────────────────────────────────────────────────────────────

cmd_load_pack() {
  local pack_file="${1:-}"

  if [[ -z "${pack_file}" ]]; then
    echo "Usage: workspace-context load packs/<pack>.yaml"
    exit 1
  fi

  # Resolve relative to workspace root if not absolute
  if [[ "${pack_file}" != /* ]]; then
    pack_file="${WORKSPACE_ROOT}/${pack_file}"
  fi

  if [[ ! -f "${pack_file}" ]]; then
    echo "Pack not found: ${pack_file}"
    if [[ -d "${PACKS_DIR}" ]]; then
      echo ""
      echo "Available packs:"
      find "${PACKS_DIR}" -name "*.yaml" -maxdepth 2 2>/dev/null | sed "s|${WORKSPACE_ROOT}/||" | sort
    fi
    exit 1
  fi

  # Mark as active
  echo "${pack_file}" > "${WORKSPACE_ROOT}/.active-pack"
  green "Loaded pack: ${pack_file}"
  echo ""

  # Print pack contents as context
  echo "=== Pack Context ==="
  cat "${pack_file}"
  echo ""
}

# ── load profile ─────────────────────────────────────────────────────────────

cmd_load_profile() {
  local profile_name="${1:-}"

  if [[ -z "${profile_name}" ]]; then
    echo "Usage: workspace-context load --profile <name>"
    echo ""
    echo "Available profiles:"
    for f in "${WORKSPACE_ROOT}/profiles/"*.yaml; do
      [[ -f "$f" ]] || continue
      printf "  %s\n" "$(basename "${f}" .yaml)"
    done
    exit 1
  fi

  local profile_file="${WORKSPACE_ROOT}/profiles/${profile_name}.yaml"
  if [[ ! -f "${profile_file}" ]]; then
    echo "Profile not found: ${profile_name}"
    echo "Looked in: ${profile_file}"
    exit 1
  fi

  # Parse profile with Python (stdlib only — no PyYAML needed for this simple YAML)
  local pack persona
  pack=$(python3 -c "
import re, pathlib
text = pathlib.Path('${profile_file}').read_text()
for line in text.splitlines():
    m = re.match(r'^pack:\s+(\S+)', line)
    if m:
        print(m.group(1))
        break
" 2>/dev/null || true)

  persona=$(python3 -c "
import re, pathlib
text = pathlib.Path('${profile_file}').read_text()
for line in text.splitlines():
    m = re.match(r'^persona:\s+(\S+)', line)
    if m:
        print(m.group(1))
        break
" 2>/dev/null || true)

  # Store active profile
  echo "${profile_name}" > "${WORKSPACE_ROOT}/.active-profile"

  green "Profile loaded: ${profile_name}"
  echo ""

  # Activate persona (if declared)
  if [[ -n "${persona}" ]]; then
    local persona_file="${WORKSPACE_ROOT}/personas/${persona}.md"
    if [[ -f "${persona_file}" ]]; then
      echo "${persona}" > "${WORKSPACE_ROOT}/.active-persona"
      green "  Persona: ${persona}"
      echo ""
      # Print persona enforcement hint block for AI context
      echo "=== Persona Constraints (${persona}) ==="
      grep -A5 '^deny:\|^allow:' "${persona_file}" 2>/dev/null | grep -v '^---' | head -20 || true
      cat "${persona_file}"
      echo ""
    else
      echo "  (persona '${persona}' not found in personas/)"
    fi
  fi

  # Activate pack (if declared and exists)
  if [[ -n "${pack}" ]]; then
    local pack_file="${WORKSPACE_ROOT}/packs/${pack}.yaml"
    if [[ -f "${pack_file}" ]]; then
      echo "${pack_file}" > "${WORKSPACE_ROOT}/.active-pack"
      green "  Pack: ${pack}"
      echo ""
      echo "=== Pack Context ==="
      cat "${pack_file}"
      echo ""
    else
      echo "  (pack '${pack}' not found — skipped)"
    fi
  fi

  # Print profile summary
  echo "=== Profile Summary ==="
  cat "${profile_file}"
  echo ""
}

# ── list profiles ────────────────────────────────────────────────────────────

cmd_list_profiles() {
  local profiles_dir="${WORKSPACE_ROOT}/profiles"
  blue "── Available Profiles ─────────────────────────────────────"
  if [[ -d "${profiles_dir}" ]]; then
    local found=0
    for f in "${profiles_dir}"/*.yaml; do
      [[ -f "$f" ]] || continue
      name=$(basename "${f}" .yaml)
      desc=$(python3 -c "
import re, pathlib
text = pathlib.Path('${f}').read_text()
for line in text.splitlines():
    m = re.match(r'^description:\s+(.+)', line)
    if m:
        print(m.group(1))
        break
" 2>/dev/null || true)
      printf "  %-25s %s\n" "${name}" "${desc}"
      found=$((found + 1))
    done
    if [[ $found -eq 0 ]]; then
      dim "  (no profiles defined — create profiles/*.yaml to get started)"
    fi
  else
    dim "  (no profiles/ directory)"
  fi
  echo ""
  echo "Usage: workspace-context load --profile <name>"
}

# ── list personas ─────────────────────────────────────────────────────────────

cmd_personas() {
  blue "── Available Personas ─────────────────────────────────────"
  if [[ -d "${PERSONAS_DIR}" ]]; then
    for f in "${PERSONAS_DIR}"/*.md; do
      [[ -f "$f" ]] || continue
      name=$(basename "${f}" .md)
      # Extract description from first non-empty line after frontmatter or heading
      desc=$(grep -m1 '^>' "${f}" 2>/dev/null | sed 's/^> //' || echo "")
      printf "  %-20s %s\n" "${name}" "${desc}"
    done
  else
    dim "  (no personas directory)"
  fi
  echo ""
  echo "Usage: workspace-context use-persona <name>"
}

cmd_use_persona() {
  local persona="${1:-}"
  if [[ -z "${persona}" ]]; then
    echo "Usage: workspace-context use-persona <name>"
    exit 1
  fi

  local persona_file="${PERSONAS_DIR}/${persona}.md"
  if [[ ! -f "${persona_file}" ]]; then
    echo "Persona not found: ${persona}"
    cmd_personas
    exit 1
  fi

  local history_file="${WORKSPACE_ROOT}/.persona-history"
  local active_persona_file="${WORKSPACE_ROOT}/.active-persona"

  # Log the transition for audit trail
  local from=""
  if [[ -f "${active_persona_file}" ]]; then
    from=$(cat "${active_persona_file}")
  fi

  local ts
  ts=$(date -u '+%Y-%m-%dT%H:%M:%SZ')
  if [[ -n "${from}" && "${from}" != "${persona}" ]]; then
    echo "${ts} transition: ${from} → ${persona}" >> "${history_file}"
    yellow "Persona transition logged: ${from} → ${persona}"
  fi

  echo "${persona}" > "${active_persona_file}"
  green "Activated persona: ${persona}"
  echo ""
  cat "${persona_file}"
}

# ── validate ──────────────────────────────────────────────────────────────────

cmd_validate() {
  local surface="${1:-all}"
  local script="${WORKSPACE_ROOT}/scripts/validate-context.sh"

  if [[ ! -f "${script}" ]]; then
    echo "Validation script not found: ${script}"
    exit 1
  fi

  bash "${script}" --surface "${surface}"
}

# ── main ──────────────────────────────────────────────────────────────────────

cmd="${1:-snapshot}"
shift || true

case "${cmd}" in
  snapshot|"") cmd_snapshot ;;
  load)
    # Distinguish --profile from a bare pack path
    if [[ "${1:-}" == "--profile" ]]; then
      cmd_load_profile "${2:-}"
    else
      cmd_load_pack "${1:-}"
    fi
    ;;
  profiles)    cmd_list_profiles ;;
  personas)    cmd_personas ;;
  use-persona) cmd_use_persona "${1:-}" ;;
  validate)    cmd_validate "${1:-all}" ;;
  help|--help|-h)
    cat <<'EOF'
workspace-context — AI Workspace session state snapshot

Usage:
  workspace-context                               Print session context snapshot
  workspace-context snapshot                      Same as above
  workspace-context load packs/<pack>.yaml        Load a context pack
  workspace-context load --profile <name>         Load a composable profile (pack+persona)
  workspace-context profiles                      List available profiles
  workspace-context personas                      List available personas
  workspace-context use-persona <name>            Activate a persona
  workspace-context validate [surface]            Validate context schemas
                                                  surface: all|packs|jobs|personas|knowledge|loops

Examples:
  workspace-context
  workspace-context load packs/my-client.yaml
  workspace-context load --profile oss-contrib
  workspace-context profiles
  workspace-context use-persona reviewer
  workspace-context validate
  workspace-context validate packs
EOF
    ;;
  *)
    echo "Unknown command: ${cmd}"
    echo "Run 'workspace-context help' for usage."
    exit 1
    ;;
esac
