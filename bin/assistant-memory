#!/usr/bin/env python3
# /// script
# requires-python = ">=3.10"
# dependencies = []
# ///
"""
bin/assistant-memory — Knowledge base management for AI Workspace

Add, search, list, and inject persistent knowledge across sessions.
"""
from __future__ import annotations

import os
import re
import shutil
import sys
import tempfile
from datetime import date, timedelta
from pathlib import Path

import json
import sqlite3
import struct
import urllib.request

WORKSPACE_ROOT = Path(os.environ.get("HARNESS_DIR", Path(__file__).resolve().parent.parent))
KNOWLEDGE = WORKSPACE_ROOT / "knowledge"


# ── colors ─────────────────────────────────────────────────────────────────────

_USE_COLOR = sys.stdout.isatty() and not os.environ.get("NO_COLOR")


def _c(code: str, text: str) -> str:
    return f"\033[{code}m{text}\033[0m" if _USE_COLOR else text


def _blue(t):   return _c("1;34", t)
def _green(t):  return _c("1;32", t)
def _yellow(t): return _c("1;33", t)
def _cyan(t):   return _c("0;36", t)
def _dim(t):    return _c("0;37", t)


# ── file helpers ───────────────────────────────────────────────────────────────

def _read(path: Path) -> str:
    return path.read_text(encoding="utf-8") if path.exists() else ""


def _write(path: Path, content: str):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")


def _prepend_after_marker(path: Path, marker: str, entry: str):
    """Insert entry after the first occurrence of marker in path."""
    content = _read(path)
    if marker not in content:
        # Fallback: append to end
        _write(path, content + "\n" + entry)
        return
    idx = content.index(marker) + len(marker)
    new_content = content[:idx] + "\n" + entry + content[idx:]
    _write(path, new_content)


def _prepend_table_row(path: Path, header_row: str, new_row: str):
    """Insert new_row right after the header row in a markdown table."""
    content = _read(path)
    if header_row not in content:
        _write(path, content + "\n" + new_row)
        return
    idx = content.index(header_row) + len(header_row)
    # Skip the separator row (---) if present
    rest = content[idx:]
    sep_match = re.match(r"\n\|[-| :]+\|", rest)
    if sep_match:
        idx += sep_match.end()
    new_content = content[:idx] + "\n" + new_row + content[idx:]
    _write(path, new_content)


# ── subcommands ────────────────────────────────────────────────────────────────

def cmd_add(args: list[str]):
    type_ = ""
    content = ""
    source_skill = ""
    from_loop = ""
    tags: list[str] = []
    i = 0
    while i < len(args):
        if args[i] == "--type" and i + 1 < len(args):
            type_ = args[i + 1]
            i += 2
        elif args[i] == "--from-skill" and i + 1 < len(args):
            source_skill = args[i + 1]
            i += 2
        elif args[i] == "--from-loop" and i + 1 < len(args):
            from_loop = args[i + 1]
            i += 2
        elif args[i] == "--tags" and i + 1 < len(args):
            tags = [t.strip() for t in args[i + 1].split(",") if t.strip()]
            i += 2
        else:
            content = args[i]
            i += 1

    if not type_ or not content:
        print("Usage: assistant-memory add --type <type> <content>")
        print("       assistant-memory add --type <type> --from-skill <name> [--from-loop <id>] [--tags a,b,c] <content>")
        print("Types: skill, process, learning, todo")
        sys.exit(1)

    today = date.today().isoformat()

    if type_ == "skill":
        path = KNOWLEDGE / "skills" / "discovered.md"
        fm_parts = [f"created: {today}"]
        if source_skill:
            fm_parts.append(f"source_skill: {source_skill}")
        if tags:
            fm_parts.append(f"tags: [{', '.join(tags)}]")
        frontmatter = "---\n" + "\n".join(fm_parts) + "\n---\n\n" if fm_parts else ""
        entry = (
            f"\n## {today} - Discovered\n\n"
            f"{frontmatter}"
            f"**What**: {content}\n"
            f"**Status**: pending-review\n\n"
            "---\n"
        )
        _prepend_after_marker(path, "<!-- Add new discoveries below -->", entry)
        print(_green(f"✓ Added skill discovery to {path.relative_to(WORKSPACE_ROOT)}"))

    elif type_ == "process":
        path = KNOWLEDGE / "processes" / "general.md"
        row = f"| {today} | {content} | New pattern |"
        if source_skill:
            row = f"| {today} | {content} | from {source_skill} |"
        _prepend_table_row(path, "| Date | What | Notes |", row)
        print(_green(f"✓ Added process pattern to {path.relative_to(WORKSPACE_ROOT)}"))

    elif type_ == "learning":
        path = KNOWLEDGE / "learnings" / "general.md"
        ctx = source_skill if source_skill else "Session"
        if from_loop:
            ctx = f"loop:{from_loop}"
        row = f"| {today} | {content} | {ctx} |"
        _prepend_table_row(path, "| Date | Learning | Context |", row)
        print(_green(f"✓ Added learning to {path.relative_to(WORKSPACE_ROOT)}"))

    elif type_ == "todo":
        path = KNOWLEDGE / "todos" / "pending.md"
        entry = f"- [ ] {today} - {content}"
        if source_skill:
            entry += f" (from {source_skill})"
        entry += "\n"
        _prepend_after_marker(path, "<!-- Add pending items with date added -->", entry)
        print(_green(f"✓ Added todo to {path.relative_to(WORKSPACE_ROOT)}"))

    else:
        print(f"Unknown type: {type_}")
        print("Valid types: skill, process, learning, todo")
        sys.exit(1)


def _parse_frontmatter(content: str) -> tuple[dict, str]:
    """Extract YAML-like frontmatter from a markdown block entry if present."""
    lines = content.strip().splitlines()
    if not lines or lines[0].strip() != "---":
        return {}, content
    end = next((i for i, l in enumerate(lines[1:], 1) if l.strip() == "---"), None)
    if end is None:
        return {}, content
    fm: dict = {}
    for line in lines[1:end]:
        if ":" in line:
            k, _, v = line.partition(":")
            raw = v.strip()
            # Simple list: [a, b, c] or starts with -
            if raw.startswith("[") and raw.endswith("]"):
                fm[k.strip()] = [x.strip().strip('"').strip("'") for x in raw[1:-1].split(",") if x.strip()]
            else:
                fm[k.strip()] = raw.strip('"').strip("'")
    return fm, "\n".join(lines[end + 1:])


def cmd_search(args: list[str]):
    # Parse flags
    query_parts: list[str] = []
    tag_filter: str | None = None
    project_filter: str | None = None
    since_filter: str | None = None
    min_conf: str | None = None
    semantic = False

    i = 0
    while i < len(args):
        match args[i]:
            case "--tag":
                tag_filter = args[i + 1]; i += 2
            case "--project":
                project_filter = args[i + 1]; i += 2
            case "--since":
                since_filter = args[i + 1]; i += 2
            case "--min-confidence":
                min_conf = args[i + 1]; i += 2
            case "--semantic":
                semantic = True; i += 1
            case _:
                query_parts.append(args[i]); i += 1

    query = " ".join(query_parts)
    if not query and not tag_filter and not project_filter:
        print("Usage: assistant-memory search [--tag T] [--project P] [--since YYYY-MM-DD] [--min-confidence low|med|high] [--semantic] <query>")
        sys.exit(1)

    if semantic:
        try:
            import sqlite_vec
        except ImportError:
            print("Semantic index requires sqlite-vec. Install with: pip install sqlite-vec")
            sys.exit(0)

        db_path = KNOWLEDGE / ".knowledge-index.db"
        if not db_path.exists():
            print(_yellow("Semantic index not found - falling back to text search"))
        else:
            conn = sqlite3.connect(str(db_path))
            conn.enable_load_extension(True)
            sqlite_vec.load(conn)
            conn.enable_load_extension(False)

            payload = json.dumps({"model": "nomic-embed-text", "input": query}).encode()
            req = urllib.request.Request(
                "http://localhost:11434/api/embeddings",
                data=payload,
                headers={"Content-Type": "application/json"},
            )
            try:
                resp = urllib.request.urlopen(req, timeout=30)
                result = json.loads(resp.read())
                query_embedding = result["embedding"]
            except Exception as e:
                print(f"Failed to get embedding: {e}")
                sys.exit(1)

            embedding_bytes = struct.pack(f"{len(query_embedding)}f", *query_embedding)
            rows = conn.execute(
                "SELECT id, distance FROM vec_entries WHERE embedding MATCH ? ORDER BY distance LIMIT 10",
                (embedding_bytes,),
            ).fetchall()

            print(f"\n{_blue(f'=== Semantic Search: {query} ===')}\n")
            found_any = False
            for entry_id, distance in rows:
                row = conn.execute("SELECT path FROM entries WHERE id = ?", (entry_id,)).fetchone()
                if not row:
                    continue
                found_any = True
                rel = row[0]
                rel_path = KNOWLEDGE / rel
                content = _read(rel_path)
                lines = content.splitlines()
                preview = " ".join(l.strip() for l in lines if l.strip())[:200]
                print(f"\U0001f4c4 {_cyan(rel)}:")
                print(f"   {_dim(f'similarity: {1 - distance:.4f}')}")
                print(f"   {_dim(preview)}")
                print()

            conn.close()
            if not found_any:
                print(_dim("  (no results found)"))
            print()
            return

    label = query if query else "(filtered)"
    print(f"\n{_blue(f'=== Searching: {label} ===')}\n")
    query_lower = query.lower() if query else ""
    conf_order = {"low": 0, "med": 1, "high": 2}
    min_conf_val = conf_order.get(min_conf or "", -1)
    found_any = False

    for md_file in sorted(KNOWLEDGE.rglob("*.md")):
        content = _read(md_file)

        # Attempt frontmatter extraction (for tagged entries)
        fm, body = _parse_frontmatter(content)

        # Frontmatter-based filters
        if tag_filter and fm:
            entry_tags = fm.get("tags", [])
            if isinstance(entry_tags, str):
                entry_tags = [entry_tags]
            if tag_filter not in entry_tags:
                continue
        elif tag_filter:
            pass  # No frontmatter — can't filter by tag

        if project_filter and fm:
            if fm.get("project", "").lower() != project_filter.lower():
                continue
        elif project_filter:
            pass

        if since_filter and fm:
            entry_date = fm.get("created", "")
            if entry_date and entry_date < since_filter:
                continue
        elif since_filter:
            pass

        if min_conf_val >= 0 and fm:
            entry_conf = conf_order.get(fm.get("confidence", ""), -1)
            if entry_conf < min_conf_val:
                continue
        elif min_conf_val >= 0:
            pass

        # Text search
        if query_lower:
            lines = content.splitlines()
            matched_lines = [
                (i + 1, line) for i, line in enumerate(lines)
                if query_lower in line.lower()
            ]
            if not matched_lines:
                continue
        else:
            matched_lines = None

        found_any = True
        rel = md_file.relative_to(WORKSPACE_ROOT)
        print(f"📄 {_cyan(str(rel))}:")
        if fm:
            meta = []
            if fm.get("tags"):
                meta.append(f"tags={fm['tags']}")
            if fm.get("project"):
                meta.append(f"project={fm['project']}")
            if fm.get("created"):
                meta.append(f"created={fm['created']}")
            if meta:
                print(f"   {_dim(' | '.join(meta))}")
        if matched_lines:
            for lineno, line in matched_lines[:5]:
                print(f"   {_dim(str(lineno) + ':')} {line.strip()}")
            if len(matched_lines) > 5:
                print(f"   {_dim(f'... and {len(matched_lines) - 5} more matches')}")
        else:
            print(f"   {_dim('(matched by filter)')}")
        print()

    if not found_any:
        print(_dim("  (no results found)"))
    print()


def cmd_list(args: list[str]):
    type_ = args[0] if args else ""

    type_map = {
        "skills":    KNOWLEDGE / "skills",
        "processes": KNOWLEDGE / "processes",
        "learnings": KNOWLEDGE / "learnings",
        "todos":     KNOWLEDGE / "todos",
    }

    if type_ and type_ in type_map:
        d = type_map[type_]
        if d.is_dir():
            for f in sorted(d.iterdir()):
                if f.is_file():
                    print(f.name)
    else:
        print(f"\n{_blue('=== Knowledge Base Contents ===')}\n")
        for section, d in type_map.items():
            print(f"{_cyan(section.capitalize())}:")
            if d.is_dir():
                files = sorted(d.iterdir())
                if files:
                    for f in files:
                        if f.is_file():
                            print(f"  - {f.name}")
                else:
                    print(_dim("  (empty)"))
            else:
                print(_dim("  (not found)"))
            print()


def cmd_todo(_args: list[str]):
    path = KNOWLEDGE / "todos" / "pending.md"
    if path.exists():
        print(path.read_text(encoding="utf-8"))
    else:
        print(_dim("(no todos file found)"))


def _update_frontmatter_field(content: str, field: str, value: str) -> str:
    """Update a frontmatter field in a markdown file content, preserving the rest."""
    lines = content.splitlines()
    if not lines or lines[0].strip() != "---":
        return content
    end = next((i for i, l in enumerate(lines[1:], 1) if l.strip() == "---"), None)
    if end is None:
        return content
    found = False
    for i in range(1, end):
        if lines[i].startswith(f"{field}:"):
            lines[i] = f"{field}: {value}"
            found = True
            break
    if not found:
        lines.insert(end, f"{field}: {value}")
    return "\n".join(lines)


def cmd_review_stale(args: list[str]):
    """Show stale entries and optionally re-confirm, edit, or delete in batch."""
    auto_renew = False
    delete_all = False
    non_interactive = False
    parsed: list[str] = []
    for a in args:
        if a == "--auto-renew":
            auto_renew = True
            non_interactive = True
        elif a == "--delete":
            delete_all = True
            non_interactive = True
        else:
            parsed.append(a)

    today = date.today().isoformat()
    next_year = (date.today() + timedelta(days=365)).isoformat()
    stale: list[tuple[Path, dict, str]] = []

    for md_file in sorted(KNOWLEDGE.rglob("*.md")):
        content = _read(md_file)
        fm, _ = _parse_frontmatter(content)
        if not fm:
            continue
        stale_after = fm.get("stale_after", "")
        if stale_after and stale_after < today:
            stale.append((md_file, fm, stale_after))

    print(f"\n{_blue('=== Stale Knowledge Entries ===')}\n")
    if not stale:
        print(_dim(f"  (no entries past their stale_after date as of {today})"))
        print()
        return

    if non_interactive:
        if auto_renew:
            count = 0
            for md_file, fm, _ in stale:
                content = _read(md_file)
                new_content = _update_frontmatter_field(content, "stale_after", next_year)
                new_content = _update_frontmatter_field(new_content, "updated", today)
                _write(md_file, new_content)
                count += 1
            print(_green(f"✓ Renewed {count} stale entries (stale_after → {next_year})"))
        elif delete_all:
            count = 0
            for md_file, fm, _ in stale:
                confirm = os.environ.get("FORCE", "") == "1"
                if not confirm:
                    rel = md_file.relative_to(WORKSPACE_ROOT)
                    print(f"Would DELETE {_yellow(str(rel))}")
                else:
                    md_file.unlink()
                    count += 1
            if not os.environ.get("FORCE"):
                print(_dim("  (dry-run — set FORCE=1 to actually delete)"))
            else:
                print(_green(f"✓ Deleted {count} stale entries"))
        print()
        return

    # Interactive batch
    renewed = 0
    edited = 0
    deleted = 0

    for md_file, fm, stale_after in stale:
        rel = md_file.relative_to(WORKSPACE_ROOT)
        print(f"\n{'='*60}")
        print(f"  📄 {_cyan(str(rel))}  (stale since {stale_after})")
        print(f"  tags={fm.get('tags', '—')}  project={fm.get('project', '—')}")
        print(f"  confidence={fm.get('confidence', '—')}")
        print()
        # Show short preview
        content = _read(md_file)
        body_lines = content.splitlines()
        preview = " ".join(line.strip() for line in body_lines if line.strip() and not line.startswith("---"))[:200]
        print(f"  {_dim('Preview:')} {preview}...")
        print()
        print(f"  {_dim('[r]')}enew (extend stale_after 1y)  {_dim('[e]')}dit  {_dim('[d]')}elete  {_dim('[s]')}kip")
        choice = input(f"  {_blue('Action')} [r/e/d/s]: ").strip().lower() if sys.stdin.isatty() else "s"

        if choice == "r":
            new_content = _update_frontmatter_field(content, "stale_after", next_year)
            new_content = _update_frontmatter_field(new_content, "updated", today)
            _write(md_file, new_content)
            renewed += 1
            print(_green(f"  ✓ Renewed until {next_year}"))
        elif choice == "e":
            new_content = _update_frontmatter_field(content, "updated", today)
            new_content = _update_frontmatter_field(new_content, "stale_after", "")
            _write(md_file, new_content)
            edited += 1
            print(_green("  ✓ Cleared stale_after — file updated"))
        elif choice == "d":
            md_file.unlink()
            deleted += 1
            print(_yellow("  ✗ Deleted"))
        else:
            print(_dim("  — Skipped"))

    print()
    print(f"{_blue('=== Batch Summary ===')}")
    print(f"  Renewed: {renewed}")
    print(f"  Edited (cleared stale): {edited}")
    print(f"  Deleted: {deleted}")
    print(f"  Skipped: {len(stale) - renewed - edited - deleted}")
    print()


def cmd_review(_args: list[str]):
    print(f"\n{_blue('=== Session Start Review ===')}\n")

    # Pending todos
    print(f"{_cyan('📋 Pending items:')}")
    todos_path = KNOWLEDGE / "todos" / "pending.md"
    if todos_path.exists():
        content = todos_path.read_text(encoding="utf-8")
        unchecked = [l for l in content.splitlines() if l.startswith("- [ ]")]
        if unchecked:
            for item in unchecked[:10]:
                print(f"  {item}")
        else:
            print(_dim("  (no pending items)"))
    else:
        print(_dim("  (no todos file)"))

    print()

    # Recent learnings
    print(f"{_cyan('📚 Recent learnings:')}")
    learnings_path = KNOWLEDGE / "learnings" / "general.md"
    if learnings_path.exists():
        content = learnings_path.read_text(encoding="utf-8")
        rows = [l for l in content.splitlines() if re.match(r"^\| \d{4}", l)]
        if rows:
            for row in rows[:5]:
                print(f"  {row}")
        else:
            print(_dim("  (no learnings recorded)"))
    print()


def cmd_inject(_args: list[str]):
    """Output a compact context block suitable for injection at session start."""
    print("<!-- assistant-memory inject -->\n")
    print("## Knowledge Base Summary\n")

    # Todos
    todos_path = KNOWLEDGE / "todos" / "pending.md"
    if todos_path.exists():
        content = todos_path.read_text(encoding="utf-8")
        unchecked = [l for l in content.splitlines() if l.startswith("- [ ]")]
        if unchecked:
            print("### Pending Todos\n")
            for item in unchecked[:10]:
                print(item)
            print()

    # Recent learnings
    learnings_path = KNOWLEDGE / "learnings" / "general.md"
    if learnings_path.exists():
        content = learnings_path.read_text(encoding="utf-8")
        rows = [l for l in content.splitlines() if re.match(r"^\| \d{4}", l)]
        if rows:
            print("### Recent Learnings\n")
            print("| Date | Learning | Context |")
            print("|------|----------|---------|")
            for row in rows[:5]:
                print(row)
            print()

    # Processes index
    procs_dir = KNOWLEDGE / "processes"
    if procs_dir.is_dir():
        proc_files = sorted(p.stem for p in procs_dir.iterdir() if p.is_file() and p.suffix == ".md")
        if proc_files:
            print("### Known Processes\n")
            for name in proc_files:
                print(f"- `knowledge/processes/{name}.md`")
            print()

    print("<!-- end assistant-memory inject -->")


def cmd_index(args: list[str]):
    try:
        import sqlite_vec
    except ImportError:
        print("Semantic index requires sqlite-vec. Install with: pip install sqlite-vec")
        sys.exit(0)

    db_path = KNOWLEDGE / ".knowledge-index.db"
    conn = sqlite3.connect(str(db_path))
    conn.enable_load_extension(True)
    sqlite_vec.load(conn)
    conn.enable_load_extension(False)

    conn.execute("""
        CREATE VIRTUAL TABLE IF NOT EXISTS vec_entries USING vec0(
            id INTEGER PRIMARY KEY,
            embedding float[768]
        )
    """)
    conn.execute("""
        CREATE TABLE IF NOT EXISTS entries (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            path TEXT UNIQUE,
            text TEXT
        )
    """)

    md_files = sorted(KNOWLEDGE.rglob("*.md"))
    print(f"Indexing {len(md_files)} files...")

    for md_file in md_files:
        content = _read(md_file)
        rel = str(md_file.relative_to(KNOWLEDGE))

        payload = json.dumps({"model": "nomic-embed-text", "input": content}).encode()
        req = urllib.request.Request(
            "http://localhost:11434/api/embeddings",
            data=payload,
            headers={"Content-Type": "application/json"},
        )

        try:
            resp = urllib.request.urlopen(req, timeout=30)
            result = json.loads(resp.read())
            embedding = result["embedding"]
        except Exception as e:
            print(f"  {_yellow('!')} Skipping {rel}: {e}")
            continue

        embedding_bytes = struct.pack(f"{len(embedding)}f", *embedding)
        conn.execute("INSERT OR REPLACE INTO entries (path, text) VALUES (?, ?)", (rel, content))
        cursor = conn.execute("SELECT id FROM entries WHERE path = ?", (rel,))
        entry_id = cursor.fetchone()[0]

        conn.execute(
            "INSERT OR REPLACE INTO vec_entries (id, embedding) VALUES (?, ?)",
            (entry_id, embedding_bytes),
        )

        print(f"  {_green('\u2713')} {rel}")

    conn.commit()
    conn.close()
    print(f"\n{_green('Index built successfully')}")


def usage():
    print(f"""
{_blue('assistant-memory')} — Manage assistant knowledge base

{_cyan('Usage:')}
  assistant-memory add --type <type> [--from-skill <name>] [--tags a,b,c] <content>
                                                  Add new entry (with optional origin tracking)
   assistant-memory search [--tag T] [--project P] [--since YYYY-MM-DD]
                    [--min-confidence low|med|high] [--semantic] <query>
                                                    Search knowledge base (with filters)
  assistant-memory index build                              Build semantic index
  assistant-memory list [type]                   List entries by type
  assistant-memory todo                          Show pending todos
  assistant-memory review                        Review key items (session start)
  assistant-memory review --stale                Review stale entries (interactive batch)
  assistant-memory review --stale --auto-renew   Auto-extend all stale entries by 1 year
  assistant-memory review --stale --delete       Delete stale entries (use FORCE=1 to execute)
  assistant-memory inject                        Output context block for injection
  assistant-memory help                          Show this help

{Cyan('Types for add:')}
  skill      New skill or tool discovery
  process    Process pattern (workflow, tool usage)
  learning   General session learning
  todo       Pending item to follow up

{Cyan('Add flags:')}
  --from-skill <name>   Origin skill name (for cross-repo traceability)
  --tags a,b,c          Comma-separated tags (applied to frontmatter for skill type)

{Cyan('Examples:')}
  assistant-memory add --type learning "Always run tests before committing"
  assistant-memory add --type skill --from-skill dots-harness-knowledge-sync --tags jira,workflow "New workflow pattern"
  assistant-memory add --type todo "Investigate slow query in reports endpoint"
  assistant-memory search "deploy"
  assistant-memory list
  assistant-memory inject   # paste output at end of session
""")


# ── main ───────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    cmd = args[0] if args else "help"
    rest = args[1:]

    dispatch = {
        "add":     cmd_add,
        "index":   cmd_index,
        "search":  cmd_search,
        "list":    cmd_list,
        "todo":    cmd_todo,
        "review":  lambda args: cmd_review_stale(args) if args and args[0] == "--stale" else cmd_review(args),
        "inject":  cmd_inject,
        "help":    lambda _: usage(),
        "--help":  lambda _: usage(),
        "-h":      lambda _: usage(),
    }

    fn = dispatch.get(cmd)
    if fn:
        fn(rest)
    else:
        print(f"Unknown command: {cmd}")
        usage()
        sys.exit(1)


if __name__ == "__main__":
    main()
